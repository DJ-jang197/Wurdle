# Copy to .env and adjust for production (do not commit .env)
WURDLE_DEBUG=false
WURDLE_HOST=127.0.0.1
WURDLE_PORT=5000
# Comma-separated origins, e.g. https://yourdomain.com
# WURDLE_CORS_ORIGINS=
WURDLE_RATE_NEW_GAME=30
WURDLE_RATE_GUESS=120
WURDLE_MAX_GAMES=5000
WURDLE_GAME_TTL_HOURS=24
WURDLE_FINISHED_TTL_HOURS=2
# Enable only for automated tests
# WURDLE_TESTING=true
